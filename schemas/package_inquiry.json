{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PackageInquiry",
  "type": "object",
  "required": ["client_id", "destination", "start_date", "end_date", "budget_min", "budget_max", "traveler_count"],
  "properties": {
    "client_id":       { "type": "string", "minLength": 1 },
    "destination":     { "type": "string", "minLength": 2 },
    "start_date":      { "type": "string", "format": "date" },
    "end_date":        { "type": "string", "format": "date" },
    "budget_min":      { "type": "number", "minimum": 0 },
    "budget_max":      { "type": "number", "minimum": 1 },
    "traveler_count":  { "type": "integer", "minimum": 1, "maximum": 50 },
    "preferences":     { "type": "array", "items": { "type": "string" } },
    "inquiry_source":  { "type": "string" }
  },
  "additionalProperties": false
}
