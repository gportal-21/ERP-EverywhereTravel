{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReservationRecord",
  "type": "object",
  "required": ["reservation_code", "quote_id", "client_id", "travel_start", "travel_end", "traveler_count", "status"],
  "properties": {
    "reservation_code": { "type": "string", "minLength": 6 },
    "quote_id":         { "type": "string" },
    "client_id":        { "type": "string" },
    "package_id":       { "type": ["string", "null"] },
    "travel_start":     { "type": "string" },
    "travel_end":       { "type": "string" },
    "traveler_count":   { "type": "integer", "minimum": 1 },
    "status":           { "type": "string", "enum": ["PENDING_PAYMENT", "CONFIRMED", "CANCELLED", "REFUNDED"] },
    "version":          { "type": "integer", "minimum": 1 },
    "created_by_agent": { "type": "string" }
  },
  "additionalProperties": false
}
