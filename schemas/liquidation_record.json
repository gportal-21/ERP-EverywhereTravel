{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LiquidationRecord",
  "type": "object",
  "required": ["liquidation_id", "reservation_code", "total_charged", "total_paid", "commission_amount", "status"],
  "properties": {
    "liquidation_id":    { "type": "string" },
    "reservation_code":  { "type": "string" },
    "total_charged":     { "type": "number", "minimum": 0 },
    "total_paid":        { "type": "number", "minimum": 0 },
    "commission_amount": { "type": "number", "minimum": 0 },
    "status":            { "type": "string", "enum": ["PARTIAL", "COMPLETE", "OVERDUE"] },
    "transactions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "amount", "method"],
        "properties": {
          "date":      { "type": "string" },
          "amount":    { "type": "number" },
          "method":    { "type": "string" },
          "reference": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": false
}
