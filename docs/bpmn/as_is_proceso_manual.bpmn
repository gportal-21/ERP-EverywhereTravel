        <di:waypoint x="1575" y="320" />
        <di:waypoint x="1575" y="275" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1291" y="383" width="78" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ConflictoOk_di" bpmnElement="Flow_ConflictoOk">
        <di:waypoint x="1525" y="460" />
        <di:waypoint x="1575" y="460" />
        <di:waypoint x="1575" y="275" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="1575" y="205" />
        <di:waypoint x="1575" y="180" />
        <di:waypoint x="1725" y="180" />
        <di:waypoint x="1725" y="150" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="1780" y="115" />
        <di:waypoint x="1840" y="115" />
        <di:waypoint x="1840" y="560" />
        <di:waypoint x="1895" y="560" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="2005" y="560" />
        <di:waypoint x="2035" y="560" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10">
        <di:waypoint x="2145" y="560" />
        <di:waypoint x="2175" y="560" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_11_di" bpmnElement="Flow_11">
        <di:waypoint x="2285" y="560" />
        <di:waypoint x="2325" y="560" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
